// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Platform {
  FACEBOOK
  INSTAGRAM
  KICK
  TIKTOK
  TWITCH
  YOUTUBE
}

enum ContentType {
  PICTURE
  STORY
  REEL
  LONG_VIDEO
  POST
  LIVE
  STREAM
}

enum MonsterAppearance {
  MONSTER_THEME
  LAYOUT
  LOGO
  MONSTER_PRODUCTS
}

enum EventAttendance {
  YES
  SOMETIMES
  NO
}

enum DiscoverySource {
  FRIEND_RECOMMENDATION
  COMMUNITY_MESSAGES
  SOCIAL_MEDIA_POSTS
  MONSTER_EVENTS
}

enum CreatorRank {
  UNRANKED
  ROOKIE
  MEGA
  RISING
  ELITE
  COLD
}

enum SubmissionRejectionReason {
  LOW_QUALITY
  WRONG_CONTENT_TYPE
  INSUFFICIENT_REACH
  GUIDELINE_VIOLATION
  DUPLICATE
  OTHER
}

enum RegistrationRejectionReason {
  INELIGIBLE_REGION
  COMPETING_BRAND
  INSUFFICIENT_FOLLOWERS
  INCOMPLETE_PROFILE
  OTHER
}

model User {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  firstName  String
  lastName   String
  username   String    @unique
  email      String?   @unique
  phone      String?   @unique
  phoneKey   String?
  isVerified Boolean   @default(false)
  isActive   Boolean   @default(true)
  role       UserRole  @default(USER)
  externalId String?
  provider   String?
  lastLogin  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  profile     CreatorProfile?
  submissions Submission[]
  snapshots   MonthlySnapshot[]
}

type PlatformLink {
  platform Platform
  url      String
}

model CreatorProfile {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @unique @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  realName          String
  contactEmail      String?
  contactPhone      String?
  nickname          String
  birthDate         String
  nationality       String
  residency         String
  platforms         Platform[]
  platformLinks     PlatformLink[]
  primarySocialLink String
  channelLogo       String?
  contentType       String
  followers         Int               @default(0)
  eventAttendance   EventAttendance
  discoverySources  DiscoverySource[]
  whyJoin           String?

  status                RegistrationStatus           @default(PENDING)
  adminNotes            String?
  adminNote             String?
  registrationRejection RegistrationRejectionReason?
  approvedAt            DateTime?

  rank              CreatorRank @default(UNRANKED)
  currentRankReach  Int         @default(0)
  totalReachAllTime Int         @default(0)

  pictureCount   Int @default(0)
  storyCount     Int @default(0)
  reelCount      Int @default(0)
  longVideoCount Int @default(0)
  postCount      Int @default(0)
  streamCount    Int @default(0)
  liveCount      Int @default(0)

  totalPictureCount   Int @default(0)
  totalStoryCount     Int @default(0)
  totalReelCount      Int @default(0)
  totalLongVideoCount Int @default(0)
  totalPostCount      Int @default(0)
  totalStreamCount    Int @default(0)
  totalLiveCount      Int @default(0)

  engagementRate  Float @default(0) //(likes+comments+shares)/reach
  commitmentScore Float @default(0) //0-15
  adminGradeScore Float @default(0) //0-30

  rankedUpAt DateTime?

  isActive  Boolean  @default(true)
  joinedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Submission {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  nickname           String
  rank               CreatorRank
  platform           Platform
  contentLink        String
  contentTypes       ContentType[]
  monsterAppearances MonsterAppearance[]

  submittedReach        Int  @default(0)
  acceptedReach         Int  @default(0)
  pendingReach          Int? // null = no pending edit
  previousAcceptedReach Int? // null = no previous

  statsScreenshotUrl String?

  engagementRate    Float? //%
  submittedLikes    Int? //
  submittedComments Int?
  submittedShares   Int?

  status          SubmissionStatus           @default(PENDING)
  adminNotes      String?
  rejectionReason SubmissionRejectionReason?
  qualityRating   Float?

  isEdited Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MonthlySnapshot {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  month           String // "YYYY-MM"
  rank            String
  reach           Int    @default(0)
  totalReach      Int    @default(0)
  engagementRate  Float  @default(0)
  commitmentScore Float  @default(0)
  adminGradeScore Float  @default(0)
  approvedSubs    Int    @default(0)

  createdAt DateTime @default(now())

  @@unique([userId, month])
}

model PlatformStat {
  id           String @id @default(auto()) @map("_id") @db.ObjectId
  userId       String @db.ObjectId
  submissionId String @unique @db.ObjectId

  platform       String
  contentTypes   String[]
  acceptedReach  Int      @default(0)
  engagementRate Float    @default(0)
  qualityRating  Float?
  rank           String

  approvedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
