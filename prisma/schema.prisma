// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Platform {
  FACEBOOK
  INSTAGRAM
  KICK
  TIKTOK
  TWITCH
  YOUTUBE
}

enum ContentType {
  PICTURE
  STORY
  REEL
  LONG_VIDEO
  POST
}

enum MonsterAppearance {
  MONSTER_THEME
  LAYOUT
  LOGO
  MONSTER_PRODUCTS
}

enum EventAttendance {
  YES
  SOMETIMES
  NO
}

enum DiscoverySource {
  FRIEND_RECOMMENDATION
  COMMUNITY_MESSAGES
  SOCIAL_MEDIA_POSTS
  MONSTER_EVENTS
}

enum CreatorRank {
  UNRANKED
  ROOKIE       // ≥ 100k total reach
  MEGA         // decorative sub-rank between Rookie and Rising
  RISING       // ≥ 500k total reach (reach resets on rank-up)
  ELITE        // decorative sub-rank between Rising and Cold
  COLD         // ≥ 1M total reach (reach never resets here)
}

model User {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  firstName  String
  lastName   String
  username   String   @unique
  email      String?  @unique
  phone      String?  @unique
  phoneKey   String?
  isVerified Boolean  @default(false)
  isActive   Boolean  @default(true)
  role       UserRole @default(USER)
  externalId String?
  provider   String?
  lastLogin  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  profile     CreatorProfile?
  submissions Submission[]
}

type PlatformLink {
  platform Platform
  url      String
}

model CreatorProfile {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @unique @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  realName         String
  contactEmail     String?
  contactPhone     String? 
  nickname         String
  birthDate        String
  nationality      String
  residency        String
  platforms        Platform[]
  platformLinks    PlatformLink[]
  primarySocialLink String
  channelLogo      String?
  contentType      String
  followers        Int      @default(0)
  eventAttendance  EventAttendance
  discoverySources DiscoverySource[]
  whyJoin          String?

  status      RegistrationStatus @default(PENDING)
  adminNotes  String?
  approvedAt  DateTime?

  rank            CreatorRank @default(UNRANKED)
  currentRankReach Int  @default(0)
  totalReachAllTime Int @default(0)

  pictureCount   Int @default(0)
  storyCount     Int @default(0)
  reelCount      Int @default(0)
  longVideoCount Int @default(0)
  postCount      Int @default(0)

  totalPictureCount   Int @default(0)
  totalStoryCount     Int @default(0)
  totalReelCount      Int @default(0)
  totalLongVideoCount Int @default(0)
  totalPostCount      Int @default(0)

  rankedUpAt DateTime?

  isActive  Boolean  @default(true)
  joinedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Submission {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  nickname     String
  rank         CreatorRank
  platform     Platform
  contentLink  String
  contentTypes ContentType[]
  monsterAppearances MonsterAppearance[]

  submittedReach  Int @default(0)
  acceptedReach   Int @default(0)
  pendingReach    Int? // null = no pending edit
  previousAcceptedReach Int? // null = no previous

  statsScreenshotUrl String?

  status      SubmissionStatus @default(PENDING)
  adminNotes  String?

  isEdited  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
